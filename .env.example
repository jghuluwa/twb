# ─────────────────────────────────────────────────────────────
# Therabo — production environment variables.
# Copy this file to `.env` (NEVER commit `.env`) and fill in real values.
# ─────────────────────────────────────────────────────────────

# Public URL the site is reachable at (used in payment success/cancel URLs
# and webhook callbacks). MUST be set correctly for Alipay / WeChat to call back.
APP_URL=https://your-domain.com

# Long random string used to sign session cookies (JWT HS256).
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string

# ── First-run admin bootstrap ──
# Used ONLY on first start when the database is empty. After that, manage
# admin accounts from the admin console.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=please-change-on-first-login

# ── CORS (only matters if frontend & backend are on different origins) ──
# In production both are served by the same container so this can stay empty.
CORS_ORIGIN=

# Max upload size in megabytes for product/hero/about images
MAX_UPLOAD_MB=10

# ─────────────────────────────────────────────────────────────
# SMTP — bootstrap defaults for outbound email. After the first
# launch you can override these from 后台 → 邮件中心 → SMTP.
# Leave empty to disable outbound mail (orders still work; auto
# emails are logged as failed and skipped).
# ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Therabo <noreply@your-domain.com>

# ─────────────────────────────────────────────────────────────
# PAYMENTS — leave any of these empty to disable that gateway.
# The cart drawer auto-hides buttons for unconfigured gateways.
# ─────────────────────────────────────────────────────────────

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Endpoint URL to register there: https://your-domain.com/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Alipay — apply at https://open.alipay.com/ (corporate verification required)
ALIPAY_APP_ID=
# PEM-formatted private key, with literal \n instead of newlines
ALIPAY_PRIVATE_KEY=
# Alipay's public key for verifying notifications (same \n encoding)
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# WeChat Pay v3 — apply at https://pay.weixin.qq.com/ (corporate verification required)
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_PUBLIC_KEY=
WECHAT_API_V3_KEY=
